// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
}


// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    memberships   Membership[]
    projectAccess ProjectMember[]
    reviewNotes   ReviewNote[]
    importBatches ImportBatch[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  members   Membership[]
  projects  Project[]
  createdAt DateTime @default(now())
}

// org-level role
model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole      @default(MEMBER)   // OWNER | ADMIN | MEMBER
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  @@unique([userId, organizationId])
}

model Project {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  articles       Article[]
  members        ProjectMember[]
  createdAt      DateTime @default(now())
  importBatches ImportBatch[]

  @@unique([organizationId, name])
}

// project-level role — separate from org role on purpose
model ProjectMember {
  id        String      @id @default(cuid())
  userId    String
  projectId String
  role      ProjectRole @default(REVIEWER)  // OWNER | REVIEWER
  user      User        @relation(fields: [userId], references: [id])
  project   Project     @relation(fields: [projectId], references: [id])
  @@unique([userId, projectId])
}

model Article {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])

  // PubMed-derived fields, mostly optional except title
  pmid            String?
  title           String
  authors         String?
  citation        String?
  firstAuthor     String?
  journal         String?
  publicationYear Int?
  createDate      DateTime?
  pmcid           String?
  nihmsId         String?
  doi             String?

  status          ReviewStatus @default(UNSCREENED) // UNSCREENED | INCLUDED | EXCLUDED | MAYBE
  reviewNotes     ReviewNote[]
  importRow       ImportRow?   @relation(fields: [importRowId], references: [id])
  importRowId     String?      @unique

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // dedup keys scoped to the project, not global
  @@unique([projectId, doi])
  @@unique([projectId, pmid])
  @@index([projectId, status])
}

model ReviewNote {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())
}

// audit trail of every import attempt — this pays for itself in the interview
model ImportBatch {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id])
  uploadedBy  String
  uploader   User   @relation(fields: [uploadedBy], references: [id])
  filename    String
  totalRows   Int
  importedRows Int
  skippedRows  Int
  createdAt   DateTime    @default(now())
  rows        ImportRow[]
}

model ImportRow {
  id            String       @id @default(cuid())
  importBatchId String
  batch         ImportBatch  @relation(fields: [importBatchId], references: [id])
  rowNumber     Int
  rawData       Json         // original row, untouched, for debugging/audit
  outcome       ImportOutcome // IMPORTED | SKIPPED_DUPLICATE | SKIPPED_INVALID
  errorMessage  String?
  article       Article?
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectRole {
  OWNER
  REVIEWER
}

enum ReviewStatus {
  UNSCREENED
  INCLUDED
  EXCLUDED
  MAYBE
}

enum ImportOutcome {
  IMPORTED
  SKIPPED_DUPLICATE
  SKIPPED_INVALID
}